<!-- Hero Section -->
<section id="hero">
  <div class="hero-content">
    <h1>Welcome to CSE Motors</h1>
  </div>
  <div class="hero-promo">
    <div class="promo-text">
      <ul class="features">
        <li>3 Cup holders</li>
        <li>Superman doors</li>
        <li>Fuzzy dice!</li>
      </ul>
      <img src="/images/site/own_today.png" alt="Own Today" class="own-today-image">
    </div>
    <div class="promo-image">
      <img src="/images/vehicles/delorean.jpg" alt="DMC DeLorean" title="DMC DeLorean">
    </div>
  </div>
</section>

<!-- Reviews Section -->
<section id="reviews">
  <h2>DMC DeLorean Reviews</h2>
  <div class="reviews-container">
    <div class="review-card">
      <p class="review-text">"So fast it's almost like traveling in time."</p>
      <div class="stars">★★★★☆</div>
      <p class="rating">4/5</p>
    </div>
    <div class="review-card">
      <p class="review-text">"Coolest ride on the road."</p>
      <div class="stars">★★★★☆</div>
      <p class="rating">4/5</p>
    </div>
    <div class="review-card">
      <p class="review-text">"I'm feeling McFly!"</p>
      <div class="stars">★★★★★</div>
      <p class="rating">5/5</p>
    </div>
    <div class="review-card">
      <p class="review-text">"The most futuristic ride of our day."</p>
      <div class="stars">★★★★☆</div>
      <p class="rating">4.5/5</p>
    </div>
    <div class="review-card">
      <p class="review-text">"80's livin and I love it!"</p>
      <div class="stars">★★★★★</div>
      <p class="rating">5/5</p>
    </div>
  </div>
</section>

<!-- Upgrades Section -->
<section id="upgrades">
  <h2>DeLorean Upgrades</h2>
  <div class="upgrades-container">
    <div class="upgrade-card">
      <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor" title="Flux Capacitor Upgrade">
      <h3>Flux Capacitor</h3>
    </div>
    <div class="upgrade-card">
      <img src="/images/upgrades/flame.jpg" alt="Flame Decals" title="Flame Decals Upgrade">
      <h3>Flame Decals</h3>
    </div>
    <div class="upgrade-card">
      <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Stickers" title="Bumper Stickers Upgrade">
      <h3>Bumper Stickers</h3>
    </div>
    <div class="upgrade-card">
      <img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps" title="Hub Caps Upgrade">
      <h3>Hub Caps</h3>
    </div>
  </div>
</section>
