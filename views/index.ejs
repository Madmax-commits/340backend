    <p class="hero-subtitle">Experience Innovation on Wheels</p>
  </div>
  <div class="hero-promo">
    <div class="promo-text">
      <h2 class="promo-title">The Iconic DeLorean</h2>
      <ul class="features">
        <li><span class="feature-icon">🏆</span> 3 Cup holders</li>
